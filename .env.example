# Database
DATABASE_URL=mongodb://pdfy:pdfy-dev@localhost:27017/pdfy?authSource=admin

# Auth
NEXTAUTH_SECRET=change-this-to-a-64-char-random-string
NEXTAUTH_URL=http://localhost:3000
JWT_EXPIRY=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pdfy-minio
S3_SECRET_KEY=pdfy-minio-secret
S3_BUCKET=pdfy-storage
S3_FORCE_PATH_STYLE=true

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Express
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
